# =============================================================================
# Fitness Center Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git!

# --- MSSQL Server ---
# Password for SQL Server SA account (minimum: 8 chars with uppercase, lowercase, digits)
MSSQL_SA_PASSWORD=YourStrong!Passw0rd

# --- JWT ---
# Generate with: openssl rand -base64 64
# Must be 512-bit (64 bytes) for HS512
JWT_SECRET=

# --- Optional overrides ---
# JAVA_OPTS=-Xmx512m -Xms256m