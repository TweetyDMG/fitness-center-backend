<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="editBox" alignment="CENTER" spacing="20" prefWidth="800" prefHeight="800" styleClass="login-box" stylesheets="@style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fitnesscenter.ui.EntityEditController">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <Label fx:id="titleLabel" styleClass="title" text="Редактирование" />
    <Label fx:id="subtitleLabel" styleClass="subtitle" text="Заполните поля" />

    <VBox fx:id="fieldsBox" spacing="10" alignment="CENTER">

    </VBox>

    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="saveButton" styleClass="btn-primary" text="Сохранить" />
        <Button fx:id="cancelButton" styleClass="btn-secondary" text="Отмена" />
    </HBox>
</VBox>