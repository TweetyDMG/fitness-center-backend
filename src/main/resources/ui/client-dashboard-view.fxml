<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fitnesscenter.ui.ClientDashboardController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    <children>
        <Label text="Активный абонемент" styleClass="title"/>
        <GridPane fx:id="activeSubscriptionPane" hgap="10" vgap="5" styleClass="grid-pane">
            <Label text="Название:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="subtitle"/>
            <Label fx:id="subscriptionNameLabel" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="Дата окончания:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="subtitle"/>
            <Label fx:id="subscriptionEndDateLabel" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label text="Осталось посещений:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="subtitle"/>
            <Label fx:id="visitsRemainingLabel" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        </GridPane>

        <Label text="Предстоящие посещения" styleClass="title"/>
        <TableView fx:id="upcomingVisitsTable" styleClass="table-view">
            <columns>
                <TableColumn fx:id="visitDateColumn" text="Дата"/>
                <TableColumn fx:id="visitTimeColumn" text="Время"/>
                <TableColumn fx:id="visitActivityColumn" text="Активность"/>
                <TableColumn fx:id="visitTrainerColumn" text="Тренер"/>
            </columns>
        </TableView>

        <Button text="Перейти к расписанию и записаться" onAction="#handleViewSchedule" styleClass="btn-primary"/>
    </children>
</VBox>