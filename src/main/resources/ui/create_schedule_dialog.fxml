<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="250.0" prefWidth="350.0" spacing="20.0" styleClass="dialog-pane" stylesheets="@style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fitnesscenter.ui.CreateScheduleDialogController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <Label styleClass="dialog-title" text="Создать новое занятие" />
    <GridPane hgap="10.0" vgap="10.0">
        <children>
            <Label text="Дата:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <DatePicker fx:id="datePicker" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Начало:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <HBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <children>
                    <Spinner fx:id="startHourSpinner" editable="true" prefWidth="70.0" />
                    <Label text=":" />
                    <Spinner fx:id="startMinuteSpinner" editable="true" prefWidth="70.0" />
                </children>
            </HBox>

            <Label text="Конец:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <HBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                <children>
                    <Spinner fx:id="endHourSpinner" editable="true" prefWidth="70.0" />
                    <Label text=":" />
                    <Spinner fx:id="endMinuteSpinner" editable="true" prefWidth="70.0" />
                </children>
            </HBox>
        </children>
    </GridPane>
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <children>
            <Button onAction="#handleCreateSchedule" styleClass="btn-primary" text="Создать" />
            <Button onAction="#handleCancel" styleClass="btn-secondary" text="Отмена" />
        </children>
    </HBox>
</VBox>