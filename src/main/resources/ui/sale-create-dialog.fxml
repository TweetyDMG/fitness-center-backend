<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.ColumnConstraints?>

<VBox spacing="15" styleClass="dialog-pane" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fitnesscenter.ui.SaleCreateDialogController">
    <padding>
        <Insets top="20" right="30" bottom="20" left="30"/>
    </padding>
    <Label text="Оформление новой продажи" styleClass="title"/>
    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints prefWidth="150"/>
            <ColumnConstraints prefWidth="300" hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Клиент:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="clientComboBox" prefWidth="300" styleClass="choice-box" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Абонемент:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="subscriptionComboBox" prefWidth="300" styleClass="choice-box" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Фитнес-центр:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="fitnessCenterComboBox" prefWidth="300" styleClass="choice-box" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Скидка (необязательно):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <ComboBox fx:id="discountComboBox" prefWidth="300" styleClass="choice-box" GridPane.rowIndex="3" GridPane.columnIndex="1" promptText="Без скидки"/>

        <Label text="Номер банковской карты:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="bankCardNumField" styleClass="text-input" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Дата начала абонемента:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <DatePicker fx:id="startDatePicker" styleClass="date-picker" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Итоговая цена:" GridPane.rowIndex="6" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="finalPriceLabel" text="0.00 руб." GridPane.rowIndex="6" GridPane.columnIndex="1" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>

    </GridPane>
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="createButton" text="Оформить" onAction="#handleCreateSale" styleClass="btn-primary"/>
        <Button fx:id="cancelButton" text="Отмена" onAction="#handleCancel" styleClass="btn-secondary"/>
    </HBox>
</VBox>