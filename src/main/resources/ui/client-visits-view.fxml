<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Priority?>

<VBox spacing="20" alignment="TOP_CENTER" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fitnesscenter.ui.ClientVisitsController" styleClass="background-pane">
    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>
    <Label text="Мои предстоящие и прошедшие посещения" styleClass="header-title"/>
    <TableView fx:id="visitsTable" styleClass="visits-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="visitDateCol" text="Дата" prefWidth="120"/>
            <TableColumn fx:id="visitTimeCol" text="Время" prefWidth="100"/>
            <TableColumn fx:id="visitActivityCol" text="Активность / Тренер" prefWidth="250"/>
            <TableColumn fx:id="visitStatusCol" text="Статус" prefWidth="120"/>
            <TableColumn fx:id="visitActionCol" text="Действие" prefWidth="100" style="-fx-alignment: CENTER;"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>