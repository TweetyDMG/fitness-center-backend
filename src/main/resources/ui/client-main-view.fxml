<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane stylesheets="@style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fitnesscenter.ui.ClientMainViewController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="50" spacing="10" styleClass="top-bar">
            <padding>
                <Insets left="10" right="10" />
            </padding>
            <Label fx:id="welcomeLabel" styleClass="title" text="Добро пожаловать, !" />
            <HBox HBox.hgrow="ALWAYS" /> <Button fx:id="logoutButton" onAction="#handleLogout" styleClass="btn-secondary" text="Выход" />
        </HBox>
    </top>
    <center>
        <TabPane fx:id="tabPane" styleClass="tab-pane" tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Панель управления">
                    <content>
                        <fx:include fx:id="dashboardTab" source="client-dashboard-view.fxml" />
                    </content>
                </Tab>
                <Tab text="Мой профиль">
                    <content>
                        <fx:include fx:id="profileTab" source="client-profile-view.fxml" />
                    </content>
                </Tab>
                <Tab text="Мои абонементы">
                    <content>
                        <fx:include fx:id="subscriptionsTab" source="client-subscriptions-view.fxml" />
                    </content>
                </Tab>
                <Tab text="Мои посещения">
                    <content>
                        <fx:include fx:id="visitsTab" source="client-visits-view.fxml" />
                    </content>
                </Tab>
                <Tab text="Расписание занятий">
                    <content>
                        <fx:include fx:id="scheduleTab" source="client-schedule-view.fxml" />
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>
