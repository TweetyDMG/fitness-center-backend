<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane prefHeight="931.0" prefWidth="1062.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fitnesscenter.ui.TrainerMainViewController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="50" spacing="10" styleClass="top-bar">
            <padding>
                <Insets left="10" right="10" />
            </padding>
            <Label fx:id="welcomeLabel" styleClass="title" text="Панель тренера - Добро пожаловать, !" />
            <HBox HBox.hgrow="ALWAYS" />
            <Button fx:id="logoutButton" onAction="#handleLogout" styleClass="btn-secondary" text="Выход" />
        </HBox>
    </top>
    <center>
        <TabPane fx:id="tabPane" styleClass="tab-pane" tabClosingPolicy="UNAVAILABLE">
        </TabPane>
    </center>
</BorderPane>
