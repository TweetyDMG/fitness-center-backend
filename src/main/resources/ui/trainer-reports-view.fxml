<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fitnesscenter.ui.TrainerReportsViewController">
    <center>
        <TableView fx:id="reportTable" prefHeight="200.0" prefWidth="200.0">
            <columns>
                <TableColumn fx:id="clientLastnameColumn" prefWidth="150.0" text="Фамилия Клиента" />
                <TableColumn fx:id="clientFirstnameColumn" prefWidth="150.0" text="Имя Клиента" />
                <TableColumn fx:id="totalVisitsColumn" prefWidth="100.0" text="Всего Посещений" />
                <TableColumn fx:id="lastVisitDateColumn" prefWidth="120.0" text="Дата Последнего Визита" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </center>
    <top>
        <Label fx:id="placeholderLabel" text="Отчёты (в разработке)" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </BorderPane.margin>
        </Label>
    </top>
    <bottom>
        <HBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
            <children>
                <Button fx:id="exportExcelButton" onAction="#handleExportExcel" text="Экспорт в Excel" />
                <Button fx:id="exportWordButton" onAction="#handleExportWord" text="Экспорт в Word" />
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
        </HBox>
    </bottom>
    <padding>
        <Insets bottom="10" left="10" right="10" top="10" />
    </padding>
</BorderPane>